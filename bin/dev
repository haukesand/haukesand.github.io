#!/usr/bin/env bash
#
# Local dev entrypoint — starts jekyll serve with an incremental build
# using the dev config overlay (skips jupyter-notebook conversion).
#
# Requires:
#   brew install ruby@3.3
#   /opt/homebrew/opt/ruby@3.3/bin/gem install bundler:2.5.7
#   ./bin/dev install    # one-time; runs bundle install
#
# Usage:
#   ./bin/dev            # jekyll serve --livereload on http://localhost:4000
#   ./bin/dev build      # one-shot build into _site/
#   ./bin/dev install    # bundle install

set -e

RUBY_PREFIX="/opt/homebrew/opt/ruby@3.3"
if [[ ! -x "$RUBY_PREFIX/bin/ruby" ]]; then
  echo "Homebrew ruby@3.3 not found at $RUBY_PREFIX." >&2
  echo "Install with: brew install ruby@3.3" >&2
  exit 1
fi

export PATH="$RUBY_PREFIX/bin:/opt/homebrew/lib/ruby/gems/3.3.0/bin:$PATH"

CMD="${1:-serve}"
shift || true

case "$CMD" in
  install)
    exec bundle install --jobs=4 "$@"
    ;;
  build)
    exec bundle exec jekyll build --config _config.yml,_config_dev.yml "$@"
    ;;
  serve)
    exec bundle exec jekyll serve --config _config.yml,_config_dev.yml --livereload --incremental "$@"
    ;;
  *)
    # Pass anything else through as a bundle subcommand.
    exec bundle "$CMD" "$@"
    ;;
esac
