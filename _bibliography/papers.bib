@comment{
  =====================================================================
   FIELD REFERENCE for this bibliography (al-folio + jekyll-scholar)
   Anything inside @comment{...} is ignored by the BibTeX parser.
  =====================================================================

  --- STANDARD BIBTEX FIELDS (drive the APA-style citation line) ---
  title, author, year, month, publisher, address, pages, volume,
  number, doi, url, isbn, issn, articleno, numpages
        Used by jekyll-scholar to build the citation. `url` does NOT
        create a button — it's only used in the citation/.bib export.
  booktitle           Venue for @inproceedings (renders as "In <booktitle>").
  journal             Venue for @article (renders italicised).
  school              Institution for @mastersthesis / @phdthesis.
  howpublished        For @misc — NOT displayed by the template; included
                      only for clean .bib export.
  keywords            Used by the bibsearch feature; not visible.
  language, day,
  eprint,
  archiveprefix,
  primaryclass        Standard BibTeX fields the template does NOT render.
                      For arXiv, use the `arxiv` field below (button).
  note                Free-text line shown under the venue. Use for things
                      like "* = equal contribution".

  --- LINK BUTTONS (each one creates a button in the links row) ---
  pdf        "PDF"     Full URL or filename (filename → /assets/pdf/<file>).
                       This is the slot for the camera-ready / published PDF.
  html       "HTML"    Canonical web page (usually the publisher page).
  arxiv      "arXiv"   Just the arXiv ID (e.g. 2505.07085); the template
                       prepends http://arxiv.org/abs/. Use for preprints.
  psyarxiv   "PsyArXiv" Full URL to a PsyArXiv preprint (custom field added
                       to this site so preprints don't squat on pdf/html).
  website    "Website" Companion / project website.
  code       "Code"    Repository URL.
  video      "Video"   Video URL (or embedded if enable_video_embedding=true).
  blog       "Blog"    Blog post URL.
  poster     "Poster"  URL or filename under /assets/pdf/.
  slides     "Slides"  URL or filename under /assets/pdf/.
  supp       "Supp"    Supplementary materials URL or filename.
  abstract   "Abs"     Triggers a collapsible block showing the abstract text.
  bibtex_show "Bib"    Set to {true} to show the "Bib" button (BibTeX popup).
  award      ——        Long award text. The "<award_name>" pill button below
                       displays whenever `award` is set. The long text itself
                       only appears on print (hidden on screen by CSS).
                       Tip: also add a `note` to keep the full text visible.
  award_name "<name>"  Label inside the award pill button (e.g. "Honorable
                       Mention"). Defaults to "Awarded" if `award` is set
                       without `award_name`.

  --- AL-FOLIO CUSTOM FIELDS (display control; NOT in the citation) ---
  selected   Legacy true|false flag. The home page used to filter on this;
             since switching to the threaded layout it is no longer read by
             selected_papers.liquid. Safe to ignore for new entries — kept
             in old entries for backwards-compatibility.
  thread     ethical-design | human-ai | data-privacy | automotive
             Controls which research-thread section the entry appears in on
             the home page. Without a `thread`, the entry shows only on the
             full /publications list.
  preview    Filename of the thumbnail in /assets/img/publication_preview/.
             ImageMagick generates responsive .webp variants at build time.
  abbr       Short venue badge shown to the left (e.g. "FAccT", "CSCW",
             "CHIWORK LBW", "AutoUI WiP"). Keep it short.
  tldr       One-sentence summary appended after the entry links row.

  =====================================================================
}

@article{Sandhaus2026-deception,
  title       = {Deception Is Ugly: Linking Aesthetic Judgment to Perceived Manipulation in Dark Patterns},
  author      = {Sandhaus, Hauke and Rhomberg, Doris Maria},
  year        = 2026,
  journal     = {Zeitschrift für Psychologie},
  publisher   = {Hogrefe Publishing},
  language    = {en},
  psyarxiv    = {https://osf.io/preprints/psyarxiv/bhfrz_v1},
  bibtex_show = {true},
  selected    = {true},
  preview     = {deception_phone_melt.png},
  thread      = {ethical-design},
  abbr        = {ZfP},
  note        = {Accepted, forthcoming},
  tldr        = {Across 126 social media users, perceived deception co-occurs strongly with negative aesthetic judgments of dark patterns (r = 0.93), pointing toward ethics-focused UX measurement scales.},
  abstract    = {Dark patterns are manipulative interface designs that exploit cognitive biases. We surveyed 126 social media users who evaluated mockups of 15 dark patterns across six strategic categories, using an adapted User Experience Questionnaire with four autonomy-focused items (pressuring, addictive, covert, deceptive). Deception co-occurred strongly with negative aesthetic judgments (r = 0.93): users rated deceptive interfaces as unattractive, whereas pressure, addictiveness, and covertness showed weaker associations. Within strategic categories, Interface Interference (r = 0.77) and Social Engineering (r = 0.72) items cohered, indicating that several categories from existing taxonomies correspond to coherent user experiences. These exploratory results are consistent with users holding tacit awareness that becomes articulable when vocabulary is provided, with the four autonomy items functioning as distinct perceptual dimensions. They point to ethics-focused UX measurement scales as a direction for capturing unethical influence alongside pragmatic and hedonic constructs.}
}

@inproceedings{Sandhaus2026-indecent,
  title       = {Making Indecent Persuasion Visible: How Evaluation Metrics Shape UX Designers' Ethical Reasoning},
  author      = {Sandhaus, Hauke and Rhomberg, Doris Maria and Nissenbaum, Helen},
  year        = 2026,
  month       = jun,
  booktitle   = {CHIWORK '26: Proceedings of the 5th Annual Symposium on Human-Computer Interaction for Work (Late-Breaking Work)},
  location    = {Linz, Austria},
  publisher   = {Association for Computing Machinery},
  address     = {New York, NY, USA},
  series      = {CHIWORK '26},
  doi         = {10.1145/3805029.3818279},
  url         = {https://doi.org/10.1145/3805029.3818279},
  html        = {https://doi.org/10.1145/3805029.3818279},
  pdf         = {https://dl.acm.org/doi/pdf/10.1145/3805029.3818279},
  keywords    = {UX metrics, dark patterns, indecent persuasion, ethical design, evaluation instruments, professional judgment},
  bibtex_show = {true},
  selected    = {true},
  preview     = {spectroscope_persuasion.png},
  thread      = {ethical-design},
  abbr        = {CHIWORK LBW},
  award       = {Best Late-Breaking Work Award at CHIWORK '26 (1 of 25)},
  award_name  = {Best LBW Award},
  poster      = {Poster/CHIwork-indecent-persuasion.pdf},
  tldr        = {In a study of 141 UX professionals, persuasion-focused evaluation metrics nearly doubled rejection of manipulative interfaces, surfacing "indecent persuasion" as a dimension standard UX instruments fail to capture.},
  abstract    = {UX evaluation tools are widely treated as neutral measurement instruments, yet the metrics designers see during evaluation may determine what they can recognise as ethically problematic. In a three-condition experiment, 141 UX professionals evaluated social media interfaces containing dark patterns. When dashboards included persuasion-focused items alongside standard User Experience Questionnaire (UEQ) data, designers rejected manipulative interfaces at nearly double the rate of a no-data baseline (56.2% vs. 30.0%). Standard UEQ data alone already produced a significant intermediate shift (43.9% rejection), so any user-testing signal recalibrates judgement. Decision confidence stayed uniformly high across conditions: designers without evaluation data were not cautiously uncertain but confidently uncalibrated, reaching different conclusions than they would have with user data while feeling equally sure. Analysis of 1,313 written justifications showed that persuasion-focused data shifted reasoning from business and aesthetic framings toward explicit engagement with manipulation, user trust, and autonomy. We introduce indecent persuasion, behavioural influence that users experience as pressuring, addictive, covert, or deceptive, as a dimension of user experience that standard instruments fail to surface. The findings raise a question about evaluation infrastructure: who decides which dimensions of user experience count?}
}

@inproceedings{Sandhaus2026-chiwork-ai,
  title       = {Interrogating GenAI Augmentation for CHIworkers: Strategies for Professional Autonomy and Accountability},
  author      = {Sandhaus, Hauke and Imteyaz, Kashif and Almutairi, Mohammed and Prajod, Pooja and Ramesh, Divya and Savage, Saiph and Yang, Qian and Muller, Michael},
  year        = 2026,
  month       = jun,
  booktitle   = {CHIWORK '26: Proceedings of the 5th Annual Symposium on Human-Computer Interaction for Work (Workshop)},
  location    = {Linz, Austria},
  publisher   = {Association for Computing Machinery},
  address     = {New York, NY, USA},
  series      = {CHIWORK '26},
  doi         = {10.1145/3805029.3818271},
  url         = {https://doi.org/10.1145/3805029.3818271},
  html        = {https://doi.org/10.1145/3805029.3818271},
  pdf         = {https://dl.acm.org/doi/pdf/10.1145/3805029.3818271},
  website     = {https://chiwork-ai.hauke.haus/},
  keywords    = {Generative AI, Professional Ethics, Future of Work, HCI Practice, Accountability, Co-thinking},
  bibtex_show = {true},
  selected    = {true},
  preview     = {brain_phone.png},
  thread      = {human-ai},
  abbr        = {CHIWORK},
  note        = {Workshop co-organizer},
  tldr        = {A CHIWORK 2026 workshop moving beyond AI disclosure statements to ask how HCI professionals can preserve deep work, intellectual autonomy, and accountability in GenAI-augmented workflows.},
  abstract    = {As Generative AI (GenAI) becomes deeply embedded in UX research, design, and software engineering, the HCI community faces a pressing challenge: balancing the acceleration of output with the risks of de-skilling, loss of flow state, and diminished accountability. The goal of this workshop is to move beyond simple AI disclosure statements to figure out how HCI professionals can maintain "deep work" and intellectual autonomy, rather than merely "scraping by" using AI outputs, and when full hand-off may be appropriate. Participants will be invited to bring concrete examples of AI-augmented workflows they consider responsible, or irresponsible, drawn from active practice. Through mapping real-world AI use and collaboratively brainstorming countermeasures, this hybrid workshop will bring together researchers and practitioners to define what ethical "co-thinking, co-creating and co-augmenting with AI" looks like. Ultimately, we aim to produce a shared repository of evolving responsible practices or a professional code of conduct, helping the community transition toward accountable, professional GenAI-augmented workflows.}
}

